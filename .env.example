# ── Twilio Credentials ──────────────────────────────────────────────────────
# Find these in your Twilio Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number that receives calls (must be in E.164 format: +1XXXXXXXXXX)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Per-Client Settings ──────────────────────────────────────────────────────
# The real cell/business phone to forward calls to
MY_CELL_NUMBER=+1XXXXXXXXXX

# Business name used in the auto-text
SHOP_NAME=Acme Plumbing

# Booking/contact link sent in the text (can be Calendly, website, etc.)
BOOKING_LINK=https://calendly.com/your-link
